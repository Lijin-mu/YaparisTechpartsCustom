{% sw_extends '@Storefront/storefront/page/checkout/confirm/index.html.twig' %}

{% block page_checkout_confirm_form_submit %}
	{% set paymentClaim = false %}
	{% if selectedPaymentMethodId is not defined %}
		{% set selectedPaymentMethodId = context.paymentMethod.id %}
	{% endif %}
	{% for payment in page.paymentMethods %}
		{% set paymentName = payment.translated.name %}
		{% if payment.id is same as(selectedPaymentMethodId) %}
			{% if paymentName =='Gewährleistungsantrag' %}
				{% set paymentClaim = true %}
			{% endif %}
		{% endif %}
	{% endfor %}
	<div class="d-grid">
		<button id="confirmFormSubmit" class="btn btn-primary btn-lg" form="confirmOrderForm" {% if page.cart.errors.blockResubmit %} disabled {% endif %} type="submit">
			{% if paymentClaim %}
				<span>{{ "techparts.checkout.confirmClaim"|trans|sw_sanitize }}</span>
			{% else %}
				<span>{{ "techparts.checkout.confirmSubmit"|trans|sw_sanitize }}</span>
			{% endif %}
		</button>
	</div>
{% endblock %}
